# ============================================
# Real Estate CRM — Environment Variables
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
# For local: mongodb://localhost:27017/realestate_crm
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/realestate_crm
MONGODB_URI=mongodb+srv://kavyanshbagotra15_db_user:Keenu2006@cluster0.oatxetb.mongodb.net/?appName=Cluster0

# JWT secrets (generate strong random strings for production)
JWT_ACCESS_SECRET=your_access_token_secret_here_change_me
JWT_REFRESH_SECRET=your_refresh_token_secret_here_change_me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# SMTP Email Configuration (used as fallback if not set in DB Settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kavyanshbagotra@gmail.com
SMTP_PASS=Keenu2006

# Google Maps API Key (used on frontend)
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key

# Default admin credentials (used by seed script)
ADMIN_EMAIL=admin@realestate.com
ADMIN_PASSWORD=Admin@123
